# === Database ===
# Railway provides DATABASE_URL automatically when you link a PostgreSQL service
# Formats accepted: postgres://, postgresql://, postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://farmsjose:CHANGE_ME@localhost:5432/farmsjose

# === Security ===
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set to true in production (HTTPS)
COOKIE_SECURE=false

# === CORS ===
CORS_ORIGINS=["http://localhost:5173"]

# === Admin seed ===
ADMIN_EMAIL=admin@farmsjose.com
ADMIN_PASSWORD=CHANGE-ME-strong-password

# === SMTP (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
EMAIL_FROM_NAME=FarmsJose

# === App ===
DEBUG=false
APP_NAME=FarmsJose API
APP_VERSION=1.0.0
PORT=8001
